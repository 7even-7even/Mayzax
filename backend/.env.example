# =========================================================
# Mayzax ATS - Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# =========================================================

# --- App ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=database_pooler_string_here
DIRECT_URL=database_direct_string_here
# --- JWT Auth ---
# Use long, random, distinct secrets in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Cookies ---
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Business Shift (IST) ---
BUSINESS_SHIFT_START_HOUR=19
BUSINESS_SHIFT_START_MINUTE=30
BUSINESS_SHIFT_END_HOUR=4
BUSINESS_SHIFT_END_MINUTE=30
BUSINESS_TIMEZONE=Asia/Kolkata

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# --- Logging ---
LOG_LEVEL=info
LOGS_DIR=logs

# --- Seed (used only by prisma/seed.ts) ---
SEED_ADMIN_EMAIL=admin@mayzaxsolutions.com
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_NAME=Mayzax Admin

# Set to "true" (or pass inline, e.g. `SEED_DEMO_DATA=true npm run seed`) to also
# generate 5 recruiters, 10 client profiles, 50 job applications, and matching
# audit logs for local development / QA. NEVER enable this in production.
SEED_DEMO_DATA=false
