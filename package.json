{
  "name": "mayzax-ats",
  "version": "1.0.0",
  "private": true,
  "description": "Mayzax ATS - Recruitment Applicant Tracking System (root orchestration scripts)",
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:extension": "npm install --prefix extension",
    "install:all": "npm run install:backend && npm run install:frontend && npm run install:extension",
    "env:backend": "cp -n backend/.env.example backend/.env || true",
    "env:frontend": "cp -n frontend/.env.example frontend/.env || true",
    "env:all": "npm run env:backend && npm run env:frontend",
    "db:generate": "npm run prisma:generate --prefix backend",
    "db:migrate": "npm run prisma:migrate --prefix backend",
    "db:migrate:deploy": "npm run prisma:migrate:deploy --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:studio": "npm run prisma:studio --prefix backend",
    "db:seed": "npm run seed --prefix backend",
    "db:seed:demo": "npm run seed:demo --prefix backend",
    "setup": "npm run install:all && npm run env:all && npm run db:generate && npm run db:migrate && npm run db:seed",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:extension": "npm run dev --prefix extension",
    "dev": "concurrently -n API,WEB,EXT -c blue,green,yellow \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:extension\"",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:extension": "npm run build --prefix extension",
    "build": "npm run build:backend && npm run build:frontend && npm run build:extension",
    "start:backend": "npm run start --prefix backend",
    "start:frontend": "npm run dev --prefix frontend",
    "start": "concurrently -n API,WEB -c blue,green \"npm:start:backend\" \"npm:start:frontend\"",
    "preview:frontend": "npm run preview --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "typecheck:extension": "npm run typecheck --prefix extension",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend && npm run typecheck:extension",
    "clean": "rimraf backend/dist backend/node_modules frontend/dist frontend/node_modules extension/dist extension/node_modules node_modules"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "concurrently": "^9.0.1",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3"
  }
}
